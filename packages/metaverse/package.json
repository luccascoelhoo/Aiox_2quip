{
  "name": "@2quip/metaverse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n game,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:game": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ server/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.80.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4",
    "easystarjs": "^0.4.4",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.1",
    "tailwindcss": "^3.4.10",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.44",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0"
  }
